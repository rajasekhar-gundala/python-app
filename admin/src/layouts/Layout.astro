---
import '../styles/global.css';

interface Props {
  title: string;
  hideNav?: boolean; // Prop to manually override nav visibility
}

const { title, hideNav = false } = Astro.props;

// LOGIC: Only show the Admin Sidebar if:
// 1. We are in the /admin/ directory
// 2. hideNav is NOT true (set on login/signup pages)
const isAdminArea = Astro.url.pathname.startsWith('/admin') || 
                    ['/inquiries', '/broadcast'].some(p => Astro.url.pathname.includes(p));

const showAdminNav = !hideNav && isAdminArea;
const user = Astro.locals.user;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Jammetry AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="antialiased text-gray-900 bg-white">
    
    {showAdminNav && (
      <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center gap-8">
              <a href="/admin/tenants" class="flex items-center gap-2">
                <span class="text-xl font-bold text-blue-600">AI Platform</span>
              </a>
              <div class="hidden md:flex gap-6">
                <a href="/admin/tenants" class="text-sm font-medium text-gray-600 hover:text-blue-600">Tenants</a>
                <a href="/admin/analytics" class="text-sm font-medium text-gray-600 hover:text-blue-600">Analytics</a>
                <a href="/admin/inquiries" class="text-sm font-medium text-gray-600 hover:text-blue-600">Inquiries</a>
                <a href="/admin/broadcast" class="text-sm font-medium text-gray-600 hover:text-blue-600">Broadcast</a>
              </div>
            </div>
            <div class="flex items-center gap-4">
              {user && <span class="text-xs text-gray-400 hidden sm:block">{user.email}</span>}
              <a href="/logout" class="text-xs font-bold text-red-600 bg-red-50 px-3 py-1 rounded-md hover:bg-red-100 transition-colors">Logout</a>
            </div>
          </div>
        </div>
      </nav>
    )}

    <slot />

    {showAdminNav && (
      <footer class="mt-20 py-10 border-t border-gray-50 text-center text-xs text-gray-400">
        &copy; 2026 Jammetry AI. Running on 2 vCPU / 8GB RAM Cluster.
      </footer>
    )}
  </body>
</html>