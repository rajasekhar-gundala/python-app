---
import '../styles/global.css';
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | AI Admin</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="antialiased text-gray-900">
    <nav class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <span class="text-xl font-bold text-blue-600">AI Platform</span>
            </div>
            <div class="hidden sm:-my-px sm:ml-6 sm:flex sm:space-x-8">
              <a href="/admin/tenants" class="text-gray-600 hover:text-blue-600 font-medium">Tenants</a>
              <a href="/admin/analytics" class="text-gray-600 hover:text-blue-600 font-medium">Analytics</a>
              <a href="/admin/inquiries" class="text-gray-600 hover:text-blue-600 font-medium">Inquiries</a>
              <a href="/admin/broadcast" class="text-blue-600 font-bold">Broadcast</a> </nav>
            </div>
          </div>
          <div class="flex items-center gap-4">
  {Astro.locals.user ? (
    /* If logged in, show the email and a real link to /logout */
    <div class="flex items-center gap-4">
      <span class="text-xs text-gray-500 hidden md:block">
        {Astro.locals.user.email}
      </span>
      <a 
        href="/logout" 
        class="text-sm font-medium text-red-600 hover:text-red-700 bg-red-50 px-3 py-1 rounded-md transition-colors"
      >
        Logout
      </a>
    </div>
  ) : (
    /* If NOT logged in, show a Login link */
    <a href="/login" class="text-sm font-medium text-blue-600 hover:text-blue-700">
      Login
    </a>
  )}
</div>
        </div>
      </div>
    </nav>

    <slot />

    <footer class="mt-20 py-10 border-t border-gray-100 text-center text-sm text-gray-400">
      &copy; 2026 AI Automation Systems. Running on 2 vCPU / 8GB RAM.
    </footer>
  </body>
</html>