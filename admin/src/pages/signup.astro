---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Sign Up - Start Your AI Assistant">
  <main class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
      <div class="text-center">
        <h2 class="text-3xl font-extrabold text-gray-900">Start Your 14-Day Trial</h2>
        <p class="mt-2 text-sm text-gray-600">
          Get your first 100 chats free. No credit card required.
        </p>
      </div>
      
      <form class="mt-8 space-y-6" action="/api/create-tenant" method="POST">
        <div class="rounded-md shadow-sm -space-y-px">
          <div class="mb-4">
            <label for="name" class="block text-sm font-medium text-gray-700">Company Name</label>
            <input name="name" type="text" required class="appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-hidden focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Acme Corp">
          </div>
          <div class="mb-4">
            <label for="email" class="block text-sm font-medium text-gray-700">Work Email</label>
            <input name="email" type="email" required class="appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-hidden focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="john@company.com">
          </div>
          <div class="mb-4">
            <label for="domain" class="block text-sm font-medium text-gray-700">Website URL</label>
            <input name="domain" type="text" required class="appearance-none rounded-lg relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-hidden focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="www.example.com">
          </div>
        </div>

        <div>
          <button type="submit" class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-bold rounded-lg text-white bg-blue-600 hover:bg-blue-700 focus:outline-hidden focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all">
            Create My AI Assistant
          </button>
        </div>
      </form>
      
      <p class="text-center text-xs text-gray-500 mt-4">
        By signing up, you agree to our Terms of Service.
      </p>
    </div>
  </main>
</Layout>