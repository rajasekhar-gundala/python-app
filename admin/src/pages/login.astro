---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';

let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    
    // Keep these trims! They were the real fix.
    const email = data.get('email')?.toString().trim(); 
    const password = data.get('password')?.toString().trim();

    if (email && password) {
      // Revert to internal network
      const pb = new PocketBase("http://pocketbase:8080");
      
      await pb.collection('users').authWithPassword(email, password);
      
      const cookieString = pb.authStore.exportToCookie({
        httpOnly: true,
        sameSite: 'lax',
        path: '/' 
      });

      return new Response(null, {
        status: 303,
        headers: {
          'Location': '/admin/tenants',
          'Set-Cookie': cookieString,
          'Cache-Control': 'no-cache'
        }
      });
    }
  } catch (e: any) {
    console.error("[LOGIN FAILED]", e.response?.message || e.message);
    errorMessage = 'Invalid email or password.';
  }
}
---

<Layout title="Login" hideNav={true}>
  <main class="min-h-screen flex items-center justify-center bg-gray-50 p-4">
    <div class="max-w-md w-full">
      <div class="flex justify-center mb-8">
        <a href="/" class="flex items-center gap-2">
          <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <span class="text-2xl font-bold tracking-tight text-gray-900">Jammetry AI</span>
        </a>
      </div>

      <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
          <h1 class="text-3xl font-bold text-gray-900">Welcome Back</h1>
          <p class="text-gray-500 mt-2">Sign in to manage your AI tenants</p>
        </div>

        {errorMessage && (
          <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm mb-6 border border-red-100 text-center">
            {errorMessage}
          </div>
        )}

        <form method="POST" class="space-y-6">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Email Address</label>
            <input type="email" name="email" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="admin@jammetry.com" />
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Password</label>
            <input type="password" name="password" required class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-blue-500 outline-none transition-all" placeholder="••••••••" />
          </div>

          <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold hover:bg-blue-700 transition-all">Sign In</button>
        </form>

        <div class="mt-8 pt-6 border-t border-gray-100 text-center">
          <p class="text-sm text-gray-600">
            Don't have an account? 
            <a href="/signup" class="text-blue-600 font-bold hover:underline">Get started for free</a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Layout>