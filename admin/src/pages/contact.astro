---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

// Variables initialized at the top for build-time safety
let success = false;
let error = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      subject: formData.get('subject'),
      message: formData.get('message'),
      status: 'new'
    };

    const pb = Astro.locals.pb;
    await pb.collection('inquiries').create(data);
    success = true;
  } catch (e) {
    error = "Something went wrong. Please try again or email support@jammetry.com";
  }
}
---

<Layout title="Contact Support - Jammetry AI">
  <main class="py-20 bg-gray-50 min-h-screen px-4">
    </main>
</Layout>