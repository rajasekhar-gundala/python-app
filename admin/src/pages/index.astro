---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const features = [
  { title: "Instant Knowledge Base", description: "Upload PDFs, Docx, or crawl your website. Our RAG system indexes everything in seconds.", icon: "📚" },
  { title: "Multi-tenant Dashboard", description: "Manage multiple clients from one central admin panel with individual usage tracking.", icon: "🏢" },
  { title: "Smart Rate Limiting", description: "Protect your resources with built-in caps. 100 chats per month on the starter tier.", icon: "🛡️" }
];

const pricing = [
  { name: "Starter", price: "$29", description: "Perfect for small local businesses.", features: ["100 AI Chats / mo", "1 Website Crawler", "Basic Widget Customization", "Email Support"], button: "Start Free Trial", highlight: false, link: "/signup" },
  { name: "Professional", price: "$79", description: "For growing companies needing more.", features: ["1,000 AI Chats / mo", "5 Document Uploads", "Advanced Brand Matching", "Priority Support"], button: "Get Started", highlight: true, link: "/signup" },
  { name: "Agency", price: "Custom", description: "Full white-label solution.", features: ["Unlimited Tenants", "Dedicated VPS Resources", "API Access", "24/7 Monitoring"], button: "Contact Sales", highlight: false, link: "mailto:sales@jammetry.com" }
];
---

<Layout title="AI Automation - Smart Chatbots for Your Business">
  <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-100 px-6 py-4">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="/" class="flex items-center gap-2">
        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
        </svg>
        <span class="text-xl font-bold tracking-tight text-gray-900">Jammetry AI</span>
      </a>
      
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
        <a href="#features" class="hover:text-blue-600 transition-colors">Features</a>
        <a href="#pricing" class="hover:text-blue-600 transition-colors">Pricing</a>
      </div>

      <div class="flex items-center gap-4">
        <a href="/login" class="text-sm font-semibold text-gray-700 hover:text-blue-600">Login</a>
        <a href="/signup" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-bold hover:bg-blue-700 transition-all shadow-sm">Sign Up</a>
      </div>
    </div>
  </nav>

  <header class="py-24 px-4 text-center bg-linear-to-b from-blue-50 to-white">
    <h1 class="text-5xl md:text-7xl font-extrabold text-gray-900 tracking-tight mb-6">
      Your Business Knowledge, <br/>
      <span class="text-blue-600">Powered by AI.</span>
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
      Deploy custom-trained AI assistants to your website in minutes. Automate support, capture leads, and scale your expertise without lifting a finger.
    </p>
    <div class="flex justify-center gap-4">
      <a href="/signup" class="btn-primary text-lg px-8 py-4 shadow-lg shadow-blue-200">Get Started for Free</a>
      <a href="#pricing" class="px-8 py-4 text-lg font-semibold text-gray-700 hover:text-blue-600 transition-colors">View Pricing &rarr;</a>
    </div>
  </header>

  <section id="features" class="py-24 max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {features.map(f => (
        <div class="p-8 bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
          <div class="text-4xl mb-4">{f.icon}</div>
          <h3 class="text-xl font-bold mb-3 text-gray-900">{f.title}</h3>
          <p class="text-gray-600 leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="pricing" class="py-24 bg-gray-50 border-y border-gray-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-gray-900 tracking-tight">Simple, Transparent Pricing</h2>
        <p class="text-gray-600 mt-4 text-lg">Choose the plan that fits your business needs.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {pricing.map(plan => (
          <div class={`relative p-8 rounded-2xl bg-white border ${plan.highlight ? 'border-blue-500 shadow-xl scale-105 z-10' : 'border-gray-200 shadow-sm'}`}>
            {plan.highlight && (
              <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-widest">
                Most Popular
              </span>
            )}
            <h3 class="text-2xl font-bold text-gray-900">{plan.name}</h3>
            <div class="mt-4 flex items-baseline gap-1">
              <span class="text-4xl font-bold">{plan.price}</span>
              <span class="text-gray-500">{plan.price !== 'Custom' ? '/mo' : ''}</span>
            </div>
            <p class="mt-4 text-gray-600 text-sm">{plan.description}</p>
            
            <ul class="mt-8 space-y-4 mb-10">
              {plan.features.map(feat => (
                <li class="flex items-center gap-3 text-gray-700 text-sm">
                  <span class="text-blue-500 font-bold">✓</span> {feat}
                </li>
              ))}
            </ul>

            <a href={plan.link} class={`block text-center w-full py-3 rounded-lg font-bold transition-all ${plan.highlight ? 'bg-blue-600 text-white hover:bg-blue-700' : 'bg-gray-100 text-gray-900 hover:bg-gray-200'}`}>
              {plan.button}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
  <footer class="bg-white border-t border-gray-100 pt-16 pb-8">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="col-span-1 md:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <span class="text-lg font-bold text-gray-900">Jammetry AI</span>
        </a>
        <p class="text-sm text-gray-500 leading-relaxed">
          The all-in-one AI automation platform for modern businesses. Built for speed, scale, and security.
        </p>
      </div>
      
      <div>
        <h4 class="font-bold text-gray-900 mb-4">Product</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <li><a href="#features" class="hover:text-blue-600">Features</a></li>
          <li><a href="#pricing" class="hover:text-blue-600">Pricing</a></li>
          <li><a href="/login" class="hover:text-blue-600">Admin Login</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-gray-900 mb-4">Support</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <li><a href="/contact" class="hover:text-blue-600">Help Center / Contact</a></li>
          <li><a href="/signup" class="hover:text-blue-600">API Docs</a></li>
          <li><a href="/signup" class="hover:text-blue-600">Community</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-gray-900 mb-4">Legal</h4>
        <ul class="space-y-2 text-sm text-gray-600">
          <li><a href="/privacy" class="hover:text-blue-600">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-blue-600">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 pt-8 border-t border-gray-50 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-gray-400">© 2026 Jammetry AI. All rights reserved.</p>
      <div class="flex gap-6">
        <span class="text-xs text-green-500 flex items-center gap-1">
          <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span> Systems Operational
        </span>
      </div>
    </div>
  </footer>
</Layout>