FROM node:22-slim AS runtime
WORKDIR /app

# 1. Install dependencies
COPY package*.json ./
RUN npm install

# 2. Copy source and build
COPY . .
RUN npm run build

# 3. Production Environment
ENV HOST=0.0.0.0
ENV PORT=4321
ENV NODE_ENV=production

EXPOSE 4321

# Start the standalone Node server generated by Astro 6
CMD ["node", "./dist/server/entry.mjs"]
